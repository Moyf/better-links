{
	"name": "obsidian-better-links",
	"version": "1.4.6",
	"description": "Better Links - Enhanced link editing for Obsidian with floating editor popover",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"preinstall": "node scripts/npm-proxy.mjs",
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"build:local": "npm run build && npm run copy-to-local",
		"copy-to-local": "node scripts/copy-to-local.mjs",
		"lint": "node scripts/lint-wrapper.mjs",
		"lint:fix": "node scripts/lint-wrapper.mjs --fix",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"upgrade": "node scripts/upgrade.mjs"
	},
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.30.1",
		"@eslint/json": "^0.14.0",
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "^8.33.1",
		"@typescript-eslint/parser": "^8.33.1",
		"esbuild": "0.25.5",
		"eslint": "^9.39.1",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"obsidian-dev-skills": "^1.0.2",
		"tslib": "2.4.0",
		"typescript": "5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@codemirror/view": "^6.38.6",
		"@popperjs/core": "^2.11.8",
		"obsidian": "latest"
	},
	"packageManager": "pnpm@10.20.0",
	"pnpm": {
		"overrides": {
			"minimatch@<3.1.3": "3.1.4",
			"minimatch@>=8.0.0 <8.0.6": "8.0.6",
			"minimatch@>=9.0.0 <9.0.7": "9.0.7",
			"ajv@>=6.0.0 <6.14.0": "6.14.0",
			"ajv@>=8.0.0 <8.18.0": "8.18.0",
			"flatted@<3.4.2": "3.4.2",
			"brace-expansion@>=1.0.0 <1.1.13": "1.1.13",
			"brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
			"picomatch@<2.3.2": "2.3.2",
			"yaml@<2.8.3": "2.8.3",
			"fast-uri@<3.1.2": "3.1.2"
		}
	}
}
